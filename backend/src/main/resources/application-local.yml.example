# ⚠️ 端口必须是 3307，不能是 3306。
#
# 本机 3306 上跑的是 MySQLPodsys —— 另一个生产项目的数据库，属于禁区：
# 不得连接、不得修改、不得在其中建库。本项目若要用本地 MySQL，必须是
# 独立实例、独立 datadir、独立端口（3307）。
#
# 注意 application.yml 的 spring.profiles.default 是 local 且 flyway.enabled=true：
# 一旦此处填成 3306 并具备权限，Flyway 会把 V1/V2 直接执行到 MySQLPodsys 上。
#
# 说明：日常本地开发用 dev profile 即可（内存/文件 H2，无需 MySQL）：
#   ./mvnw spring-boot:run -Dspring-boot.run.profiles=dev
# 本文件仅在你确实需要对着真实 MySQL 调试时使用。
spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3307/lynxiglam?useUnicode=true&characterEncoding=utf8&connectionTimeZone=UTC&allowPublicKeyRetrieval=true&useSSL=false
    username: lynxiglam
    password: change-me
    hikari:
      maximum-pool-size: 5
      minimum-idle: 1
      connection-timeout: 3000
