# Copy to `.env.local` to point the storefront at the local Spring Boot backend.
# Use `localhost` (not 127.0.0.1) so the SameSite=Lax session cookie is treated
# as same-site with the Next dev server on localhost:3000.
# The URL MUST include the /api context-path.
#
# Start the backend first:
#   $env:JAVA_HOME = "$PWD\.tools\jdk21\jdk-21.0.11"
#   cd backend; .\mvnw.cmd spring-boot:run -Dspring-boot.run.profiles=dev
NEXT_PUBLIC_DATA_SOURCE=api
NEXT_PUBLIC_API_URL=http://localhost:8090/api
