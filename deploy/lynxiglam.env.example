# =====================================================================
# deploy/lynxiglam.env.example  ->  /etc/lynxiglam/lynxiglam.env
#
#   sudo install -d -m 0750 -o root -g root /etc/lynxiglam
#   sudo install -m 0600 -o root -g root lynxiglam.env.example /etc/lynxiglam/lynxiglam.env
#   sudo ${EDITOR} /etc/lynxiglam/lynxiglam.env
#   sudo chmod 600 /etc/lynxiglam/lynxiglam.env && sudo chown root:root /etc/lynxiglam/lynxiglam.env
#
# THE REAL FILE IS root:root, chmod 0600, AND IS NEVER COMMITTED.
# Only this .example (with empty values) belongs in git. systemd reads
# EnvironmentFile= as root BEFORE dropping to lynxiglam-api, so the service
# account itself needs no read access — 0600 root:root is correct, not
# over-tight. `deploy/*.env` is gitignored alongside this file.
#
# systemd EnvironmentFile syntax, not shell: plain KEY=VALUE, no `export`, no
# command substitution, no quotes needed (and `&` is literal). Value runs to
# end of line.
# =====================================================================

# --- Database ---------------------------------------------------------
# Loopback only. sslMode=DISABLED + allowPublicKeyRetrieval=true are acceptable
# ONLY because this never leaves 127.0.0.1 (the unit also enforces
# IPAddressAllow=localhost). Over any real network this pair is a MITM hazard.
# The database name MUST be `lynxiglam`. It must NEVER be podsys, kejing,
# kejing_staging or test_kejing — those belong to other tenants on this host.
DB_URL=jdbc:mysql://127.0.0.1:3306/lynxiglam?useUnicode=true&characterEncoding=utf8&connectionTimeZone=UTC&sslMode=DISABLED&allowPublicKeyRetrieval=true

DB_USER=lynxiglam

# From deploy/mysql/001-bootstrap.sql. Generate: openssl rand -base64 32
# Never reuse any podsys/kejing credential (secrets are a separate ownership
# boundary).
DB_PASSWORD=

# --- Storefront -------------------------------------------------------
# Feeds app.storefront-origin (application.yml) -> the CORS allowlist in
# SecurityConfig.java, which runs with allowCredentials=true. A wildcard or a
# stale value here is a credentialed-CORS hole. Exact scheme+host, no trailing
# slash.
STOREFRONT_ORIGIN=https://lynxiglam.kejing.online

# --- Admin bootstrap --------------------------------------------------
# DELIBERATELY ABSENT from this file. Admin credentials belong to the one-shot
# provisioning run only (deploy/lynxiglam-admin-provision.env.example), never to
# the environment of a long-running internet-facing process — where they would
# sit in /proc/<pid>/environ for the life of the service and re-apply on every
# restart. See RUNBOOK step 17.
