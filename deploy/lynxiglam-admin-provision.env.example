# =====================================================================
# deploy/lynxiglam-admin-provision.env.example
#   ->  /etc/lynxiglam/admin-provision.env   (root:root 0600)
#
# TRANSIENT. Create it, run the provisioning command (RUNBOOK step 17), then:
#   sudo shred -u /etc/lynxiglam/admin-provision.env
# It must never be referenced by lynxiglam-api.service.
# =====================================================================

APP_ADMIN_EMAIL=admin@lynxiglam.kejing.online

# Preferred: point at a separate root:root 0600 file holding ONLY the password.
# Keeps it out of /proc/<pid>/environ even for the brief provisioning run.
#   ( umask 077; openssl rand -base64 24 > /etc/lynxiglam/admin-password.txt )
APP_ADMIN_PASSWORD_FILE=/etc/lynxiglam/admin-password.txt

# Fallback (comment out APP_ADMIN_PASSWORD_FILE to use). Minimum 16 chars —
# AdminProvisionRunner refuses anything shorter.
# APP_ADMIN_PASSWORD=

APP_ADMIN_ROLE=ADMIN

# NEVER pass the password as a CLI argument: argv is world-readable via
# /proc/<pid>/cmdline, and every other tenant's `ps` on this shared host sees it.
