# /etc/logrotate.d/lynxiglam-nginx
#
# INSTALL ONLY IF /etc/logrotate.d/nginx does NOT already glob /var/log/nginx/*.log.
# Verify first: grep -n 'var/log/nginx' /etc/logrotate.d/nginx
# In most distros the stock nginx logrotate already covers these files, in which
# case this file is redundant and must NOT be installed (double-rotation).
/var/log/nginx/lynxiglam.access.log /var/log/nginx/lynxiglam.error.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    create 0640 www-data adm
    sharedscripts
    postrotate
        # USR1 reopens log files. Never `systemctl restart nginx` here — it
        # would sever every co-tenant vhost's in-flight connections nightly.
        [ -f /run/nginx.pid ] && kill -USR1 "$(cat /run/nginx.pid)"
    endscript
}
