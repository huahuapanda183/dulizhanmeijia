# --- Data source ---------------------------------------------------------
# "mock" (default) serves data from src/lib/data/*.
# "api" makes every function in src/lib/api/* fetch from NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_DATA_SOURCE=mock

# Base URL of your backend (used only when NEXT_PUBLIC_DATA_SOURCE=api).
# e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Example of a server-only secret you'd add when wiring real payments/auth.
# (Never expose secrets with the NEXT_PUBLIC_ prefix.)
# STORE_API_SECRET=
