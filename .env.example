# 复制为 .env.local 后按需修改。
# 注意：NEXT_PUBLIC_* 会在 `next build` 时被内联进产物——数据源在构建那一刻就固定了，
# 构建完成后再改环境变量不会生效。

# --- 数据源 ---------------------------------------------------------------
# mock：默认。数据来自 src/lib/data/*，无需后端即可跑通整站。
# api ：src/lib/api/* 的所有函数改为请求 NEXT_PUBLIC_API_URL。
NEXT_PUBLIC_DATA_SOURCE=mock

# --- 后端地址（仅当 DATA_SOURCE=api 时使用）--------------------------------
# 必须包含 /api 这个 context-path，例如 http://localhost:8090/api
#
# 本地请用 localhost 而非 127.0.0.1：两者虽同为回环地址，但浏览器视作不同站点，
# 用 127.0.0.1 会使 SameSite=Lax 的会话 Cookie 对 localhost:3000 的前端失效。
#
# 本地联调步骤（需自行安装 JDK 21 并设置 JAVA_HOME）：
#   1) cd backend && ./mvnw spring-boot:run -Dspring-boot.run.profiles=dev
#   2) 本文件复制为 .env.local，并设为：
#        NEXT_PUBLIC_DATA_SOURCE=api
#        NEXT_PUBLIC_API_URL=http://localhost:8090/api
#   3) 重启 npm run dev
NEXT_PUBLIC_API_URL=
